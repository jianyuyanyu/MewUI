<Project>

  <PropertyGroup>
    <MewUITitle>Aprillz.MewUI</MewUITitle>
    <MewUIVersion>0.18.1</MewUIVersion>
    <MewUIAuthor>Aprillz</MewUIAuthor>
    <MewUIDescription>A cross-platform and lightweight, code-first .NET GUI framework aimed at NativeAOT</MewUIDescription>

    <MewUIRootNamespace>Aprillz.MewUI</MewUIRootNamespace>
    <MewUITargetFrameworks>net8.0;net10.0</MewUITargetFrameworks>
    <MewUIPackageLicenseExpression>MIT</MewUIPackageLicenseExpression>
    <MewUIRepositoryUrl>https://github.com/aprillz/MewUI</MewUIRepositoryUrl>
    <MewVGVersion>0.5.5</MewVGVersion>
  </PropertyGroup>

  <!-- Local development override (gitignored) - MewVGProjectPath, etc. -->
  <Import Project="MewUI.Local.props" Condition="Exists('MewUI.Local.props')" />

  <PropertyGroup>
    <TargetFrameworks>$(MewUITargetFrameworks)</TargetFrameworks>
    <Version>$(MewUIVersion)</Version>
    <Authors>$(MewUIAuthor)</Authors>
    <RootNamespace>$(MewUIRootNamespace)</RootNamespace>
    <PackageLicenseExpression>$(MewUIPackageLicenseExpression)</PackageLicenseExpression>
    <PackageProjectUrl>$(MewUIRepositoryUrl)</PackageProjectUrl>
    <RepositoryUrl>$(MewUIRepositoryUrl)</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <Copyright>Copyright (c) $(MewUIAuthor)</Copyright>
    <PackageIcon>logo_c-256.png</PackageIcon>

    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IsTrimmable>true</IsTrimmable>
    <SuppressTrimAnalysisWarnings>false</SuppressTrimAnalysisWarnings>

    <PublishRepositoryUrl>false</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <IncludeSource>true</IncludeSource>
    <DebugType>portable</DebugType>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <!-- Shared icon + third-party notices in every package. -->
  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)..\assets\logo\logo_c-256.png" Pack="true" PackagePath="\" Visible="false" />
    <None Include="$(MSBuildThisFileDirectory)..\THIRD_PARTY_NOTICES.md" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

  <!-- Package README: own NUGET_README.md (nuget-facing, concise), else own README.md, else shared root NUGET_README.md. -->
  <Choose>
    <When Condition="Exists('$(MSBuildProjectDirectory)\NUGET_README.md')">
      <PropertyGroup>
        <PackageReadmeFile>NUGET_README.md</PackageReadmeFile>
      </PropertyGroup>
      <ItemGroup>
        <None Include="NUGET_README.md" Pack="true" PackagePath="\" />
      </ItemGroup>
    </When>
    <When Condition="Exists('$(MSBuildProjectDirectory)\README.md')">
      <PropertyGroup>
        <PackageReadmeFile>README.md</PackageReadmeFile>
      </PropertyGroup>
      <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
      </ItemGroup>
    </When>
    <Otherwise>
      <PropertyGroup>
        <PackageReadmeFile>NUGET_README.md</PackageReadmeFile>
      </PropertyGroup>
      <ItemGroup>
        <None Include="$(MSBuildThisFileDirectory)..\NUGET_README.md" Pack="true" PackagePath="\" Visible="false" />
      </ItemGroup>
    </Otherwise>
  </Choose>

</Project>
